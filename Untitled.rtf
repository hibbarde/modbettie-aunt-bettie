const parseModule = (text) => \{\
  const m = text.match(/^\\[MODULE:(\\w+)\\]/);\
  return m ? m[1] : null;\
\};\
const stripModuleTag = (text) => text.replace(/^\\[MODULE:\\w+\\]\\n?/, "");\
const parseChoices = (text) => \{\
  const multiMatch = text.match(/\\[CHOICES:MULTI:\\s*([^\\]]+)\\]/);\
  const singleMatch = text.match(/\\[CHOICES:\\s*([^\\]]+)\\]/);\
  const match = multiMatch || singleMatch;\
  if (!match) return \{ clean: text, choices: [], multi: false \};\
  const choices = match[1].split("|").map(c => c.trim()).filter(Boolean);\
  // Auto-detect multi if MULTI tag OR more than 6 options\
  const multi = !!multiMatch || choices.length > 6;\
  const clean = text.replace(/\\[CHOICES:(?:MULTI:)?\\s*[^\\]]+\\]/, "").trimEnd();\
  return \{ clean, choices, multi \};\
\};\
