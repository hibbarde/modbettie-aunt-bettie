              <div style=\{\{display:"flex",justifyContent:m.role==="user"?"flex-end":"flex-start"\}\}>\
                \{m.role==="assistant" && <div style=\{\{marginRight:"10px",marginTop:"4px",flexShrink:0,opacity:0.65\}\}><MoonIcon/></div>\}\
                <div style=\{\{maxWidth:"82%",padding:"16px 20px",borderRadius:m.role==="user"?"20px 20px 4px 20px":"4px 20px 20px 20px",background:m.role==="user"?"linear-gradient(135deg,#c1622f,#8b3d1a)":"rgba(255,255,255,0.03)",border:m.role==="user"?"none":"1px solid rgba(193,98,47,0.09)",color:m.role==="user"?"#fdf0e6":"#e8ddd0",fontSize:"15px",lineHeight:"1.75"\}\}>\
                  \{renderText(clean)\}\
                </div>\
              </div>\
              \{showChoices && !multi && (\
                <div style=\{\{display:"flex",flexWrap:"wrap",gap:"8px",marginTop:"10px",marginLeft:"34px"\}\}>\
                  \{choices.map((choice, ci) => \{\
                    const key = `$\{i\}-$\{choice\}`;\
                    const used = usedChoices.has(key);\
                    return (\
                      <button key=\{ci\} onClick=\{()=>handleChoice(choice, i)\} disabled=\{choicesUsed\}\
                        style=\{\{padding:"9px 16px",border:`1px solid $\{used?"rgba(193,98,47,0.6)":"rgba(193,98,47,0.25)"\}`,background:used?"rgba(193,98,47,0.15)":"transparent",color:used?"#c1622f":choicesUsed?"rgba(255,255,255,0.15)":"rgba(240,230,216,0.65)",fontSize:"13px",fontFamily:"Georgia,serif",fontStyle:"italic",cursor:choicesUsed?"default":"pointer",borderRadius:"30px",transition:"all 0.2s",opacity:choicesUsed&&!used?0.4:1\}\}>\
                        \{choice\}\
                      </button>\
                    );\
                  \})\}\
                </div>\
              )\}\
              \{showChoices && multi && !usedChoices.has(`$\{i\}-done`) && (\
                <div style=\{\{marginTop:"10px",marginLeft:"34px"\}\}>\
                  <div style=\{\{display:"flex",flexWrap:"wrap",gap:"8px",marginBottom:"12px"\}\}>\
                    \{choices.map((choice, ci) => \{\
                      const selected = (multiSelections[i] || new Set()).has(choice);\
                      return (\
                        <button key=\{ci\} onClick=\{()=>toggleMulti(i, choice)\}\
                          style=\{\{padding:"9px 16px",border:`1px solid $\{selected?"rgba(193,98,47,0.6)":"rgba(193,98,47,0.25)"\}`,background:selected?"rgba(193,98,47,0.15)":"transparent",color:selected?"#c1622f":"rgba(240,230,216,0.65)",fontSize:"13px",fontFamily:"Georgia,serif",fontStyle:"italic",cursor:"pointer",borderRadius:"30px",transition:"all 0.2s"\}\}>\
                          \{choice\}\
                        </button>\
                      );\
                    \})\}\
                  </div>\
                  <button onClick=\{()=>submitMulti(i)\}\
                    disabled=\{!(multiSelections[i]?.size > 0)\}\
                    style=\{\{padding:"10px 24px",border:"1px solid rgba(193,98,47,0.5)",background:"rgba(193,98,47,0.15)",color:"#c1622f",fontSize:"12px",letterSpacing:"2px",textTransform:"uppercase",fontFamily:"Georgia,serif",cursor:"pointer",borderRadius:"30px"\}\}>\
                    That's me \uc0\u8594 \
                  </button>\
                </div>\
              )\}\
            </div>\
          );\
        \})\}\
\
        \{isSummary && (\
          <div style=\{\{display:"flex",gap:"12px",justifyContent:"center",flexWrap:"wrap",padding:"8px 0"\}\}>\
            <button onClick=\{()=>setShowResults(true)\} style=\{\{padding:"12px 24px",border:"1px solid rgba(193,98,47,0.5)",background:"rgba(193,98,47,0.1)",color:"#c1622f",fontSize:"11px",letterSpacing:"3px",textTransform:"uppercase",cursor:"pointer",fontFamily:"Georgia,serif",borderRadius:"30px"\}\}>\uc0\u10022  View Your Style Card</button>\
            <button onClick=\{()=>setShowPhotog(true)\} style=\{\{padding:"12px 24px",border:"1px solid rgba(255,255,255,0.1)",background:"rgba(255,255,255,0.03)",color:"rgba(255,255,255,0.4)",fontSize:"11px",letterSpacing:"3px",textTransform:"uppercase",cursor:"pointer",fontFamily:"Georgia,serif",borderRadius:"30px"\}\}>Photographer Brief</button>\
          </div>\
        )\}\
\
        \{loading && (\
          <div style=\{\{display:"flex",justifyContent:"flex-start",alignItems:"center",gap:"10px"\}\}>\
            <div style=\{\{opacity:0.6\}\}><MoonIcon/></div>\
            <div style=\{\{padding:"16px 20px",borderRadius:"4px 20px 20px 20px",background:"rgba(255,255,255,0.03)",border:"1px solid rgba(193,98,47,0.09)",display:"flex",gap:"7px",alignItems:"center"\}\}>\
              \{[0,1,2].map(n=><div key=\{n\} style=\{\{width:"5px",height:"5px",borderRadius:"50%",background:"#c1622f",animation:"br 1.4s ease-in-out infinite",animationDelay:`$\{n*0.25\}s`\}\}/>)\}\
            </div>\
          </div>\
        )\}\
        <div ref=\{bottomRef\}/>\
      </div>\
\
      <div style=\{\{width:"100%",maxWidth:"680px",borderTop:"1px solid rgba(193,98,47,0.07)"\}\}/>\
      <div style=\{\{width:"100%",maxWidth:"680px",padding:"14px 20px 28px",display:"flex",gap:"10px",alignItems:"flex-end"\}\}>\
        <textarea value=\{input\} onChange=\{e=>setInput(e.target.value)\} onKeyDown=\{handleKey\}\
          placeholder="Or type your own answer\'85" rows=\{1\}\
          style=\{\{flex:1,padding:"13px 16px",borderRadius:"14px",border:"1px solid rgba(193,98,47,0.18)",background:"rgba(255,255,255,0.03)",color:"#e8ddd0",fontSize:"15px",fontFamily:"Georgia,serif",resize:"none",outline:"none",lineHeight:"1.6"\}\}/>\
        <button onClick=\{()=>sendMessage(input)\} disabled=\{loading||!input.trim()\} style=\{\{width:"44px",height:"44px",borderRadius:"50%",border:"1px solid rgba(193,98,47,0.3)",background:loading||!input.trim()?"transparent":"rgba(193,98,47,0.15)",color:loading||!input.trim()?"rgba(193,98,47,0.2)":"#c1622f",fontSize:"17px",cursor:loading||!input.trim()?"not-allowed":"pointer",display:"flex",alignItems:"center",justifyContent:"center",transition:"all 0.2s",flexShrink:0\}\}>\uc0\u8594 </button>\
      </div>\
\
      <style>\{`\
        @keyframes br\{0%,100%\{opacity:0.2;transform:scale(0.7)\}50%\{opacity:1;transform:scale(1.2)\}\}\
        textarea::placeholder\{color:rgba(232,221,208,0.18)\}\
        textarea:focus\{border-color:rgba(193,98,47,0.35)\}\
        ::-webkit-scrollbar\{width:3px\}\
        ::-webkit-scrollbar-thumb\{background:rgba(193,98,47,0.12)\}\
      `\}</style>\
    </div>\
  );\
\}}